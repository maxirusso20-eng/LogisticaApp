# ─────────────────────────────────────────────
# .env.example — Expo / React Native
# Copiá este archivo como .env y completá con los datos del cliente.
# NUNCA subas .env a git. Ya está en .gitignore.
# ─────────────────────────────────────────────

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_xxxx

# Rol admin — el email del usuario que tiene acceso completo
EXPO_PUBLIC_ADMIN_EMAIL=admin@empresa.com

# Branding — personalizable por cliente
EXPO_PUBLIC_APP_NAME=Mi Logística
EXPO_PUBLIC_APP_TAGLINE=Panel de Control · Área Logística
EXPO_PUBLIC_APP_VERSION=1.0.0